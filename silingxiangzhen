<template>
  <div class="tech-container">
    <!-- 顶部：日期选择（左右滑动） -->
    <div class="wheel-container top-wheel">
      <div class="wheel" ref="topWheelRef">
        <div 
          class="wheel-item"
          :class="{ active: selectedDate === item }"
          v-for="item in dateList" 
          :key="item"
        >
          {{ item }}
        </div>
      </div>
      <div class="wheel-indicator"></div>
    </div>

    <div class="middle-section">
      <!-- 左侧：题材选择（上下滑动） -->
      <div class="wheel-container left-wheel">
        <div class="wheel vertical" ref="leftWheelRef">
          <div 
            class="wheel-item"
            :class="{ active: selectedTopic === item }"
            v-for="item in topicList" 
            :key="item"
          >
            {{ item }}
          </div>
        </div>
        <div class="wheel-indicator"></div>
      </div>

      <!-- 中间：结果展示区 -->
      <div class="center-display">
        <h2 class="glow-text">当前筛选</h2>
        <div class="info-card">
          <p>📅 日期：{{ selectedDate || '请选择日期' }}</p>
          <p>📚 题材：{{ selectedTopic || '请选择题材' }}</p>
          <p>📌 主题：{{ selectedTheme || '请选择主题' }}</p>
          <p>✍️ 作者：{{ selectedAuthor || '请选择作者' }}</p>
        </div>
      </div>

      <!-- 右侧：作者选择（上下滑动） -->
      <div class="wheel-container right-wheel">
        <div class="wheel vertical" ref="rightWheelRef">
          <div 
            class="wheel-item"
            :class="{ active: selectedAuthor === item }"
            v-for="item in authorList" 
            :key="item"
          >
            {{ item }}
          </div>
        </div>
        <div class="wheel-indicator"></div>
      </div>
    </div>

    <!-- 底部：主题选择（左右滑动） -->
    <div class="wheel-container bottom-wheel">
      <div class="wheel" ref="bottomWheelRef">
        <div 
          class="wheel-item"
          :class="{ active: selectedTheme === item }"
          v-for="item in themeList" 
          :key="item"
        >
          {{ item }}
        </div>
      </div>
      <div class="wheel-indicator"></div>
    </div>
  </div>
</template>

<script setup>
import { ref, onMounted } from 'vue'

// 模拟数据
const dateList = ['5/10', '5/11', '5/12', '5/13', '5/14', '5/15', '5/16']
const topicList = ['玄幻', '科幻', '武侠', '仙侠', '都市']
const themeList = ['宿命对决', '时空穿越', '秘境探险', '上古秘闻', '科技觉醒']
const authorList = ['星尘客', '雾隐者', '夜行者', '云中子', '风语者']

// 选中状态
const selectedDate = ref('')
const selectedTopic = ref('')
const selectedTheme = ref('')
const selectedAuthor = ref('')

// 滚轮DOM引用
const topWheelRef = ref(null)
const leftWheelRef = ref(null)
const rightWheelRef = ref(null)
const bottomWheelRef = ref(null)

// 通用滚轮滑动逻辑
const useWheelScroll = (wheelRef, list, selectedRef, isVertical = false) => {
  let startPos = 0
  let isDragging = false

  const handleStart = (e) => {
    isDragging = true
    startPos = isVertical ? e.touches?.[0]?.clientY || e.clientY : e.touches?.[0]?.clientX || e.clientX
    wheelRef.value.style.transition = 'none'
  }

  const handleMove = (e) => {
    if (!isDragging) return
    const currentPos = isVertical ? e.touches?.[0]?.clientY || e.clientY : e.touches?.[0]?.clientX || e.clientX
    const diff = isVertical ? startPos - currentPos : currentPos - startPos
    wheelRef.value.scrollBy(isVertical ? 0 : diff * 0.5, isVertical ? diff * 0.5 : 0)
    startPos = currentPos
  }

  const handleEnd = () => {
    isDragging = false
    wheelRef.value.style.transition = 'scroll-behavior 0.3s ease'
    // 自动对齐到中心项
    const scrollPos = isVertical ? wheelRef.value.scrollTop : wheelRef.value.scrollLeft
    const itemSize = isVertical ? 60 : 80
    const index = Math.round(scrollPos / itemSize)
    const clampedIndex = Math.max(0, Math.min(index, list.length - 1))
    wheelRef.value.scrollTo({
      [isVertical ? 'top' : 'left']: clampedIndex * itemSize,
      behavior: 'smooth'
    })
    selectedRef.value = list[clampedIndex]
  }

  wheelRef.value?.addEventListener('touchstart', handleStart)
  wheelRef.value?.addEventListener('touchmove', handleMove)
  wheelRef.value?.addEventListener('touchend', handleEnd)
  wheelRef.value?.addEventListener('mousedown', handleStart)
  wheelRef.value?.addEventListener('mousemove', handleMove)
  wheelRef.value?.addEventListener('mouseup', handleEnd)
  wheelRef.value?.addEventListener('mouseleave', handleEnd)
}

onMounted(() => {
  // 初始化四个滚轮
  useWheelScroll(topWheelRef, dateList, selectedDate)
  useWheelScroll(leftWheelRef, topicList, selectedTopic, true)
  useWheelScroll(rightWheelRef, authorList, selectedAuthor, true)
  useWheelScroll(bottomWheelRef, themeList, selectedTheme)

  // 默认选中第一个
  selectedDate.value = dateList[0]
  selectedTopic.value = topicList[0]
  selectedTheme.value = themeList[0]
  selectedAuthor.value = authorList[0]
})
</script>

